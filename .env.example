# Rehearsal Compose environment template. Copy to .env and fill real values.
# .env is gitignored (never commit secrets). All services bind LAN-only.

# Interface the APP services bind to (LAN-only; never 0.0.0.0 / WAN): Ollama
# (:11434 — unauthenticated, incl. model pull/delete), STT (:8000/:8001), Kokoro
# (:8880), web (:3000), LiveKit WS signaling (:7880). Keep this at 127.0.0.1 even
# when serving other LAN devices — these are unauthenticated and the TLS proxy
# reaches them over the internal docker network, so they never need a LAN bind.
LAN_BIND_IP=127.0.0.1

# Interface the LAN-FACING ports bind to (F18): the LiveKit WebRTC media ports
# (7881/tcp, 7882/udp) and, with docker-compose.proxy.yml, the TLS front doors
# (443, 7443). Media flows browser->host directly (bypassing the proxy), so these
# DO need LAN reachability to serve other devices. Defaults to LAN_BIND_IP, so a
# local install needs nothing; for LAN serving set ONLY this (plus LIVEKIT_NODE_IP
# and NEXT_PUBLIC_LIVEKIT_URL) to the host LAN IP and leave LAN_BIND_IP loopback.
PROXY_BIND_IP=127.0.0.1

# LiveKit self-host API credentials. Injected into the server as LIVEKIT_KEYS
# ("<key>: <secret>") and used by the web token-mint endpoint to sign JWTs.
# Use a long random secret in real deploys (never commit the real .env).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace-with-a-long-random-secret

# Browser-visible LiveKit WS endpoint (the browser connects here directly).
# Default ws://localhost:7880 works out-of-the-box for a local install:
# localhost is a secure context, so plain ws:// is fine (no TLS needed). For
# other LAN devices you must front LiveKit with TLS (wss://<lan-ip>:7443) — see
# the optional TLS reverse-proxy section in README.md. Only the WS URL is exposed
# to the browser; LIVEKIT_API_KEY/SECRET stay server-side in the token route.
# NOTE: baked into the web bundle at BUILD time — changing it needs
# `docker compose build web`.
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# IP the LiveKit server advertises as its ICE host candidate (--node-ip). Must be
# an address the browser can reach or WebRTC media never flows. We pin it (rather
# than use_external_ip:true) to avoid any STUN/WAN egress.
#   - Local install (browser on this box), Chromium/Chrome: 127.0.0.1 just works.
#   - FIREFOX needs media.peerconnection.ice.loopback=true to accept a 127.0.0.1
#     candidate (it drops loopback ICE by default), so Chromium/Chrome is the
#     recommended browser for a local install — no config required.
#   - Other LAN devices: set this (and LAN_BIND_IP) to the host's LAN IP and use
#     the TLS reverse-proxy (README.md).
LIVEKIT_NODE_IP=127.0.0.1

# Ollama VRAM-budget env (Plan 01-02 validates these empirically).
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
# v1.2 R2 model lifecycle. OLLAMA_MAX_LOADED_MODELS=1 (docker-compose.yml) already
# enforces single-residency, so OLLAMA_KEEP_ALIVE defaults to -1 (always-resident) to
# protect the voice-to-voice P50<1.0s metric — a finite idle-unload only adds a cold
# reload on the next utterance, no VRAM gain. Set a finite value (e.g. 10m) to free idle
# VRAM on a shared host; set OLLAMA_MAX_LOADED_MODELS=2 in compose on a roomy GPU for
# warm Fast<->Better swaps.
OLLAMA_KEEP_ALIVE=-1
# The two user-selectable response-model tags (Phase 8, LLM-03) — resolved by
# ollama/pull-and-pin.sh. Fast is the default (LLM-02). NO hardcoded gemma tag in
# code: the agent reads these env vars (resolved_model_tag). The picker surfaces
# OUTCOME labels only ("Fast (snappier)" / "Better (more thoughtful)") — never the
# raw tag (LLM-01).
OLLAMA_MODEL_FAST=evalengine/unbound-e2b:latest
OLLAMA_MODEL_BETTER=defyma85/gemma-4-E4B-it-ultra-uncensored-heretic-Q4_K_M_gguf:latest
# v1.2 R2: the ~6GB Floor tier's model (abliterated small Qwen3) — resolved by
# pull-and-pin.sh's FLOOR_LADDER. Optional: unset on non-floor hardware. The R7
# installer sets REHEARSAL_DEFAULT_MODEL=floor on weak GPUs to boot on this model.
OLLAMA_MODEL_FLOOR=
# Session default model choice (fast|better|floor). The R7 installer sets this to
# "floor" on weak GPUs so the host boots on the floor model. Unset/invalid -> "fast".
# REHEARSAL_DEFAULT_MODEL=fast
# Back-compat alias: existing scripts (warmup.py / vram-validate.sh / kb/distill.py
# / Modelfile) read OLLAMA_MODEL, so point it at the Fast/default tag so they keep
# working unchanged (RESEARCH §7.3).
OLLAMA_MODEL=evalengine/unbound-e2b:latest

# R7 install-set: which models were pulled + their picker labels.
# REHEARSAL_MODEL_CHOICES=fast,better,floor
# NEXT_PUBLIC_REHEARSAL_MODEL_LABELS=Fast,Better,Floor
# Windows-AMD native Ollama (off-stack; agent reaches host Ollama by URL):
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_GENERATE_URL=http://host.docker.internal:11434/api/generate

# Buffered Parakeet STT (R3 final). The model tag is single-source for the GPU STT:
# this env var + the Compose build.args/environment default + the stt/Dockerfile
# ARG all share it, so the BAKED weights and the LOADED model never drift. NO
# hardcoded tag lives in the agent or server code (the v1.0 no-hardcoded-tag
# invariant) — only the Compose default below carries the literal.
STT_MODEL=nvidia/parakeet-tdt-0.6b-v2
# Revision pin for the baked GPU STT weights. NeMo's from_pretrained has no
# revision arg, so the Docker build snapshot-downloads THIS revision and runs
# offline from that cache. Pin a commit SHA here if you need byte-stable rebuilds.
STT_MODEL_REVISION=main
# Legacy streaming-only: att_context_size = [left, right] in 80 ms encoder frames. MUST be a
# trained setting: one of [70,13] [70,6] [70,1] [70,0]. Right-context is the
# latency/accuracy/cut-off dial: [70,1] = 80 ms lookahead (snappiest), [70,6] = 480 ms
# (accuracy-first), [70,13] = ~1040 ms (most lookahead → best trailing-word capture).
# [56,3] / anything off-list is UNTRAINED — do not use (degrades accuracy).
STT_ATT_CONTEXT_SIZE=[70,6]
# HOOK (STT-F1, not built this phase): a future cyber-vocabulary fine-tuned .nemo
# can be swapped in with ZERO code change — point STT_MODEL at the custom
# checkpoint and rebuild. No fine-tune code/data ships in Phase 9.
# --- STT conversation-feel knobs (FEEL-02; defaults live in stt/server.py) --------
# Live STT chunk/endpointing. In buffered Parakeet mode, finalization happens after
# two silent chunks: 320ms * 2 = about 640ms of captured post-speech silence.
STT_STREAM_CHUNK_MS=320
STT_ENDPOINT_SILENCE_MS=640

# Legacy off-GPU CPU-ONNX streaming runtime. The same single-source / no-
# hardcoded-tag invariant as STT_MODEL above: the literal default lives ONLY in the
# Compose build.args/environment for nemo-stt-cpu — the agent/server/Dockerfile.cpu
# body carry it via env/ARG, so the BAKED ONNX artifact and the LOADED one never
# drift. STT_ONNX_MODEL is the CPU analog of STT_MODEL (the exported ONNX bundle id).
STT_ONNX_SOURCE_MODEL=nvidia/nemotron-speech-streaming-en-0.6b
STT_ONNX_MODEL=nvidia/nemotron-speech-streaming-en-0.6b-onnx
# Quant profile selector. int8-dynamic (~0.88 GB on disk) is the stock-onnxruntime,
# CI/Docker-reproducible DEFAULT (encoder-only quantize_dynamic). int4-kquant
# (~0.67 GB, the literal STT-05 number) is an OPERATOR-GATED stretch build (custom
# k-quant + MHA fusion — NOT stock); do NOT assume 4-bit works out of the box.
STT_QUANT=int8-dynamic
# NOTE: STT_RUNTIME is set PER-SERVICE in docker-compose.yml (gpu on nemo-stt, cpu on
# nemo-stt-cpu), NOT here — consistent with the Wave-1 (10-01) per-service runtime.

# STT_ENGINE selects the MODE:
#   buffered = default Parakeet final path. On GPU this uses NeMo ASRModel.transcribe()
#   with nvidia/parakeet-tdt-0.6b-v2; on CPU it uses the baked sherpa-onnx bundle.
#   streaming/hybrid = legacy manual modes retained for comparison only.
# Per-tier defaults are recommended by scripts/gpu-doctor.sh (R3 Plan B), never auto-written.
STT_ENGINE=buffered
# Device for the legacy sherpa-onnx Parakeet backend (cpu|gpu). The CPU service
# forces cpu; the GPU service's default buffered path uses backend_parakeet_nemo.
STT_BUFFERED_DEVICE=cpu
# Offline-baked Parakeet ONNX model dir (set in the image; override to relocate).
# STT_PARAKEET_MODEL=/models/parakeet-tdt-0.6b-v2-onnx-int8

# Total GPU VRAM in MB. agent/placement.py uses this as the GPU-STT fit ceiling
# (total − 1GB headroom); scripts/gpu-doctor.sh prints the detected value to copy here.
# Default 16384 (the 16GB floor) when unset. Only consulted once STT_HEADROOM_MEASURED=1.
# VRAM_TOTAL_MB=16384

# STT placement picker (Phase 10 Wave 2, STT-06/STT-07). agent/placement.py resolves
# STT (GPU Parakeet vs CPU Parakeet/legacy ONNX) ONCE at session start from the worst-case LLM + the static
# measured-headroom table; the agent connects to NEMO_STT_URL (gpu) or NEMO_STT_CPU_URL
# (cpu) accordingly.
#
# STT_FORCE_CPU is the documented SAFE DEFAULT: =1 pins CPU STT for BOTH LLM choices
# (Fast and Better) before any headroom logic, so the picker is VRAM-safe out of the
# box. On good NVIDIA hardware, use GPU buffered Parakeet for speed: run with
# `--profile stt-gpu`, set STT_FORCE_CPU=0 and STT_HEADROOM_MEASURED=1, and keep
# STT_ENGINE=buffered.
#
# COMPOSE TOPOLOGY (M5): the GPU `nemo-stt` service is behind the `stt-gpu` Compose
# profile, so the DEFAULT `docker compose up` brings up ONLY the always-on CPU STT
# (`nemo-stt-cpu`) and the GPU STT never resident-loads its ~3.2 GB — the VRAM the
# placement table assumes CPU-STT frees stays free. To run the GPU cell, opt in with
# `docker compose --profile stt-gpu up` AND set STT_FORCE_CPU=0 + STT_HEADROOM_MEASURED=1.
STT_FORCE_CPU=1
# The measured gate: the GPU branch of the resolver is LOCKED OFF until the operator
# measures the real Kokoro footprint + runs the co-residency matrix and flips this to
# 1. Until then placement defaults to CPU even with STT_FORCE_CPU=0 (the
# default-CPU-when-unmeasured lock — the KOKORO_MB constant is an unmeasured placeholder).
STT_HEADROOM_MEASURED=0
# NEMO_STT_CPU_URL is a CODE DEFAULT (ws://nemo-stt-cpu:8000/v1/audio/stream), parity
# with NEMO_STT_URL which is code-default-only — the agent reaches the CPU service by
# this URL when placement resolves to cpu. Override here only for a non-default topology.
