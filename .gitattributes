# Normalize line endings across platforms.
#
# Files consumed inside the Linux Docker builds/containers (shell scripts,
# Dockerfiles, entrypoints, env/config) MUST be LF. On a Windows checkout with
# core.autocrlf=true (the Git-for-Windows default) they would otherwise arrive as
# CRLF, and bash chokes on the trailing \r — e.g. `set -o pipefail` fails with
# "invalid option name", breaking `docker compose build`. This bites the one-line
# installers, which git-clone a fresh copy on the user's machine.
#
# Default every text file to LF; keep Windows-native script types as CRLF.
* text=auto eol=lf

*.sh    text eol=lf
*.bash  text eol=lf

*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.onnx  binary
*.bin   binary
*.gguf  binary
*.model binary
